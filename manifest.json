{
  "manifest_version": 3,
  "name": "AnimePahe Enhancer",
  "short_name": "AP Enhancer",
  "version": "0.0.3",
  "description": "Continue Watching with video progress tracking + DUB episode detection for AnimePahe.",

  "browser_specific_settings": {
    "gecko": {
      "id": "animepahe-enhancer@abdullahkhfb.github.io",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {}
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["storage"],

  "host_permissions": [
    "*://*.animepahe.pw/*",
    "*://*.animepahe.org/*",
    "*://*.animepahe.com/*",
    "*://*.kwik.cx/*",
    "*://*.kwik.sh/*",
    "*://*.kwik.si/*",
    "*://*.kwik.bz/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://*.animepahe.pw/*",
        "*://*.animepahe.org/*",
        "*://*.animepahe.com/*",
        "*://*.animepahe.ru/*"
      ],
      "js": ["content/animepahe.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.kwik.cx/*",
        "*://*.kwik.sh/*",
        "*://*.kwik.si/*",
        "*://*.kwik.bz/*"
      ],
      "js": ["content/iframe-player.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AnimePahe Enhancer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
